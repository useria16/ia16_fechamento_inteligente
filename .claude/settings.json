{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./backend/.env)",
      "Read(./frontend/.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ],
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run test)",
      "Bash(pytest)",
      "Bash(alembic *)",
      "Bash(docker compose ps)"
    ]
  }
}
